# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{js,jsx,ts,tsx}]
indent_size = 2

[*.json]
indent_size = 2

[*.sh]
indent_size = 2

[Makefile]
indent_style = tab

[*.py]
indent_size = 4

[*.{cs,java}]
indent_size = 4

[*.go]
indent_size = 4

[*.rs]
indent_size = 4

[*.{html,css,scss,less}]
indent_size = 2

[*.{xml,svg}]
indent_size = 2
