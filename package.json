{
  "name": "git-github-practice",
  "version": "1.0.0",
  "description": "A learning and practice repository for Git and GitHub workflows",
  "main": "src/index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "validate": "npm run lint && npm run test",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/username/git-github-practice.git"
  },
  "keywords": [
    "git",
    "github",
    "version-control",
    "learning",
    "tutorial"
  ],
  "author": "Your Name",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/username/git-github-practice/issues"
  },
  "homepage": "https://github.com/username/git-github-practice#readme",
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.2"
  },
  "lint-staged": {
    "*.{js,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
