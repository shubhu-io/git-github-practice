{
  "name": "git-github-practice",
  "version": "2.0.0",
  "description": "A complete Git & GitHub learning repository with 110+ files — from first commit to advanced CI/CD",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "validate": "npm run lint && npm run test && npm run format:check",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shubhu-io/git-github-practice.git"
  },
  "keywords": [
    "git",
    "github",
    "version-control",
    "learning",
    "tutorial",
    "automation",
    "ci-cd"
  ],
  "author": "Shubhu-io",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shubhu-io/git-github-practice/issues"
  },
  "homepage": "https://github.com/shubhu-io/git-github-practice#readme",
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^30.4.2",
    "prettier": "^3.0.3",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.2"
  },
  "lint-staged": {
    "*.{js,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
