# npm configuration
# https://docs.npmjs.com/cli/v10/configuring-npm/npmrc

# Use strict SSL
strict-ssl=true

# Engine strict mode
engine-strict=true

# Save exact versions
save-exact=true

# Package lock
package-lock=true

# Log level
loglevel=warn

# Registry
registry=https://registry.npmjs.org/

# Cache
cache=~/.npm

# Prefer offline
prefer-offline=false

# Save prefix
save-prefix=^

# Yes to prompts
yes=true

# Audit
audit=true

# Progress bar
progress=true
